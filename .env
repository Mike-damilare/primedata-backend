# ===== MOCK MODE =====
# Set to "true" to fake Paystack/VTpass responses (no real keys needed).
# Set to "false" once you have real keys to go LIVE.
MOCK_MODE=true

# ===== CASHBACK ECONOMICS =====
# Your average margin on data bundles (wholesale cost vs retail price).
# UPDATE THIS to your real number — cashback is calculated as a % of THIS, not of sale price,
# so it auto-protects your profit even if wholesale costs change.
DATA_MARGIN_RATE=0.07

# ===== SERVER =====
PORT=4000
JWT_SECRET=change_this_to_a_long_random_string

# ===== PAYSTACK =====
# Get these from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# ===== VTPASS =====
# Get these from https://vtpass.com/ (sandbox: https://sandbox.vtpass.com/)
VTPASS_API_URL=https://sandbox.vtpass.com/api
VTPASS_USERNAME=your_vtpass_email
VTPASS_PASSWORD=your_vtpass_password
VTPASS_API_KEY=your_vtpass_api_key
VTPASS_SECRET_KEY=your_vtpass_secret_key

# ===== RELOADLY (Ghana, Kenya, South Africa, Egypt) =====
# Get these from https://www.reloadly.com/ (sandbox: https://topups-sandbox.reloadly.com)
RELOADLY_API_URL=https://topups-sandbox.reloadly.com
RELOADLY_CLIENT_ID=your_reloadly_client_id
RELOADLY_CLIENT_SECRET=your_reloadly_client_secret
